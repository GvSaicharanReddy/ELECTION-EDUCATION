# =============================================================
# Election Saathi India — Environment Variables
# =============================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit the .env file — it is excluded by .gitignore.
# =============================================================

# --- Google Gemini / Vertex AI ---
# Get your API key from: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-1.5-flash
VITE_GOOGLE_CLOUD_PROJECT=

# --- Google Maps ---
# Enable Maps JavaScript API at: https://console.cloud.google.com/apis
# Restrict your key to the Maps JavaScript API and your domain.
VITE_GOOGLE_MAPS_API_KEY=

# --- Google Calendar ---
# Create OAuth 2.0 credentials at: https://console.cloud.google.com/apis/credentials
# Set authorized redirect URI to your app's origin (e.g., http://localhost:3000)
# Required scope: https://www.googleapis.com/auth/calendar.events
VITE_GOOGLE_CALENDAR_CLIENT_ID=
VITE_GOOGLE_CALENDAR_API_KEY=

# --- Application ---
VITE_APP_ENV=development
